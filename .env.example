# ============================================================
# Context-Aware Retrieval Engine — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# -----------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------
# Base URL of the FastAPI backend, accessible from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------
# Google Cloud / Vertex AI (production)
# -----------------------------------------------------------
# Path to a Google Cloud service-account JSON key file.
# Required only when running against real Vertex AI.
# In development the mock backend is used automatically.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Your GCP project ID.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI region (e.g. us-central1, asia-southeast1).
VERTEX_AI_LOCATION=us-central1

# -----------------------------------------------------------
# Model selection
# -----------------------------------------------------------
# Embedding model (Vertex AI textembedding or HuggingFace ID).
EMBEDDING_MODEL=textembedding-gecko@003

# Fallback / local embedding model (sentence-transformers).
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding vector dimension (must match the model above).
EMBEDDING_DIMENSION=384

# Generative model used for query expansion.
GENERATIVE_MODEL=gemini-3.1-pro-preview

# -----------------------------------------------------------
# Retrieval & ranking
# -----------------------------------------------------------
# Default number of results to return.
DEFAULT_TOP_K=5

# Minimum cosine-similarity threshold for Strategy A.
SEMANTIC_THRESHOLD=0.0

# BM25 k1 and b parameters.
BM25_K1=1.5
BM25_B=0.75

# Reciprocal Rank Fusion constant (k).
RRF_K=60

# Cross-encoder model for optional reranking.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# -----------------------------------------------------------
# Caching
# -----------------------------------------------------------
# Backend: sqlite | memory | json
EMBEDDING_CACHE_BACKEND=sqlite

# Path to the SQLite cache file (relative to backend/).
EMBEDDING_CACHE_PATH=./data/cache/embeddings.db

# Maximum number of entries in the in-memory LRU cache.
EMBEDDING_CACHE_MAX_SIZE=10000

# -----------------------------------------------------------
# FastAPI server
# -----------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------
# Data paths
# -----------------------------------------------------------
# Path to the corpus YAML / JSON file ingested at startup.
CORPUS_PATH=./data/corpus.json

# Directory where FAISS index files are persisted.
VECTOR_STORE_PATH=./data/vector_store

# -----------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------
# Set to "true" to enable structured JSON logging.
JSON_LOGS=false

# OpenTelemetry collector endpoint (leave blank to disable).
OTEL_EXPORTER_OTLP_ENDPOINT=
